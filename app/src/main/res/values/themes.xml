<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.RaktVahini" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_soft</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Background and Surface colors -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Customize your theme here. -->
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.RaktVahini.LargeComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.RaktVahini.MediumComponent</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.RaktVahini.SmallComponent</item>

        <!-- Button Styles -->
        <item name="materialButtonStyle">@style/Widget.RaktVahini.Button</item>
    </style>

    <!-- Shape Appearances for "Cute" Rounded Corners -->
    <style name="ShapeAppearance.RaktVahini.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.RaktVahini.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.RaktVahini.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Reusable Button Style -->
    <style name="Widget.RaktVahini.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.RaktVahini.MediumComponent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.RaktVahini.Button.Secondary" parent="Widget.RaktVahini.Button">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
    </style>

    <style name="Widget.RaktVahini.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearance">@style/ShapeAppearance.RaktVahini.MediumComponent</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Reusable Card Style -->
    <style name="Widget.RaktVahini.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.RaktVahini.MediumComponent</item>
    </style>

    <style name="Widget.RaktVahini.Card.Soft" parent="Widget.RaktVahini.Card">
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>